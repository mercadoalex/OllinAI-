{
  "name": "ollinai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src/ || true",
    "lint:strict": "eslint src/ --ext .ts,.tsx --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:properties": "vitest run tests/properties",
    "audit:security": "npm audit --audit-level=high",
    "audit:deps": "npx depcheck --ignores='@types/*,typescript,vitest,fast-check,@playwright/test,esbuild'",
    "quality": "npm run lint && npm run test:coverage && npm run audit:security",
    "db:local:create": "npx tsx scripts/create-local-tables.ts",
    "db:local:recreate": "npx tsx scripts/create-local-tables.ts --force",
    "db:seed": "npx tsx scripts/seed-demo-data.ts"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/client-eventbridge": "^3.1058.0",
    "@aws-sdk/client-sqs": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "@tailwindcss/postcss": "^4.3.0",
    "bcryptjs": "^3.0.3",
    "lucide-react": "^1.17.0",
    "next": "^14.2.0",
    "next-auth": "^4.24.0",
    "next-themes": "^0.4.6",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.48.0",
    "@types/aws-lambda": "^8.10.161",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitest/coverage-v8": "2.1",
    "autoprefixer": "^10.5.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.9",
    "fast-check": "^3.22.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.61.0",
    "vitest": "^2.1.0"
  }
}
